    {
      "parameters": {
        "jsCode": "let text = $json.content || \"\";\n\n// Juste supprimer les URLs\ntext = text.replace(/https?:\\/\\/[^\\s\\]]+/g, '');\n\n// Supprimer les lignes qui sont juste des crochets vides\ntext = text.replace(/\\n\\s*\\[\\s*\\n/g, '\\n');\n\n// Supprimer multiples sauts de ligne\ntext = text.replace(/\\n{3,}/g, '\\n\\n');\n\nreturn { json: { \n  content: text.trim()\n}};"
      },
